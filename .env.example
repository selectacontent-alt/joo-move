PORT=
# Public site origin used for absolute upload links inside WhatsApp messages.
SITE_URL=
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
BOSTA_API_KEY=
ARAMEX_API_KEY=
# Mount a persistent volume/host directory at this path. Uploads are not copied into the app container.
UPLOAD_DIR=/data/uploads
WHATSAPP_AUTH_DIR=
WHATSAPP_CLIENT_ID=joo-move-client
WHATSAPP_DATA_DIR=
WHATSAPP_QUEUE_DIR=
WHATSAPP_QUEUE_MIN_DELAY_MS=15000
WHATSAPP_QUEUE_MAX_DELAY_MS=30000
WHATSAPP_TYPING_DELAY_MS=20000
WHATSAPP_VERIFY_NUMBER_BEFORE_SEND=true
WHATSAPP_NUMBER_LOOKUP_TIMEOUT_MS=10000
WHATSAPP_SEND_TASK_TIMEOUT_MS=90000
WHATSAPP_MAX_TRANSIENT_RETRIES=0
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_PROTOCOL_TIMEOUT_MS=300000
